def select_crypto_by_coin_symbol_name(df: pd.DataFrame, *args):
    logger.debug('start the coins selection')
    keys_name = []
    wrong_args = []

    if '*' in args:
        logger.debug('finish without data changes')
        return df

    for arg in args:
        if arg in df['symbol'].values:
             keys_name.append(arg)
        else:
             wrong_args.append(arg)
            
    if not keys_name:
        logger.error('You have wrotten the worng keys')
        return None
    if wrong_args:
        logger.warning(f'There is some wrong keys: {wrong_args}, the keys {keys_name} is succesfully confirmed')
    if keys_name:
        logger.info('finish selection successfully')
        return df[df['symbol'].isin(keys_name)]
   
        
